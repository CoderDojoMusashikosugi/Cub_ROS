<robot name="mcub" xmlns:cubsim="https://github.com/tomoki-na/Cub_ROS/cubsim">
  <!--
    mCub simulation model template.

    Coordinate convention:
      x: forward, y: left, z: up
      base_link: kept at the same height as the existing cub_description/mcub.urdf

    Confirmed from cub_description/urdf/mcub.urdf:
      drive wheel diameter: 0.040 m
      displayed axle/tread span: 0.130 m (used provisionally as wheel track)

    NOTE(INPUT): wheel_odometry.cpp and control_mcub_moter_node.cpp use 0.125 m
    as the drive-wheel center-to-center distance.  Confirm whether the simulation
    track should be 0.130 m (description model) or 0.125 m (control model).

    TODO(INPUT): Replace the provisional values below with measured/CAD values.
      - base_mass, base_cog_*, and base inertia
      - wheel_width, wheel_mass, wheel inertia, effort, and velocity limits
      - caster pivot position, trail, wheel size, masses, and inertias
      - SLC1_link position, especially lidar_scan_z (actual scan-plane height)

    Generate plain URDF before importing into Unity:
      xacro mcub.urdf.xacro -o mcub.urdf
  -->
  <material name="mcub_white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="mcub_gray">
    <color rgba="0.35 0.35 0.35 1"/>
  </material>
  <material name="mcub_black">
    <color rgba="0.08 0.08 0.08 1"/>
  </material>
  <link name="base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.045 0.0 0.07"/>
      <mass value="1.0"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.003" iyz="0.0" izz="0.004"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="-0.045 0 0.07"/>
      <geometry>
        <box size="0.15 0.11 0.08"/>
      </geometry>
      <material name="mcub_white"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.045 0 0.07"/>
      <geometry>
        <box size="0.15 0.11 0.08"/>
      </geometry>
    </collision>
  </link>
  <joint name="base_to_footprint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <link name="base_footprint"/>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin rpy="0 0 0" xyz="0.0 0.0625 0.02"/>
    <axis xyz="0 1 0"/>
    <limit effort="1.0" velocity="20.0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>
  <link name="left_wheel_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1.2e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1.2e-05"/>
    </inertial>
    <visual>
      <origin rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.015" radius="0.02"/>
      </geometry>
      <material name="mcub_gray"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.015" radius="0.02"/>
      </geometry>
    </collision>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin rpy="0 0 0" xyz="0.0 -0.0625 0.02"/>
    <axis xyz="0 1 0"/>
    <limit effort="1.0" velocity="20.0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>
  <link name="right_wheel_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1.2e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1.2e-05"/>
    </inertial>
    <visual>
      <origin rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.015" radius="0.02"/>
      </geometry>
      <material name="mcub_gray"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.015" radius="0.02"/>
      </geometry>
    </collision>
  </link>
  <!-- Passive trailing caster: free swivel about z plus free wheel rotation about y. -->
  <joint name="caster_swivel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="caster_swivel_link"/>
    <origin rpy="0 0 0" xyz="-0.1 0 0.04"/>
    <axis xyz="0 0 1"/>
    <limit effort="0.1" velocity="30.0"/>
    <dynamics damping="0.02" friction="0.0"/>
  </joint>
  <link name="caster_swivel_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0075 0 -0.02"/>
      <mass value="0.02"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
    </inertial>
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="-0.0075 0 -0.02"/>
      <geometry>
        <cylinder length="0.015" radius="0.004"/>
      </geometry>
      <material name="mcub_gray"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="-0.0075 0 -0.02"/>
      <geometry>
        <cylinder length="0.015" radius="0.004"/>
      </geometry>
    </collision>
  </link>
  <joint name="caster_wheel_joint" type="continuous">
    <parent link="caster_swivel_link"/>
    <child link="caster_wheel_link"/>
    <origin rpy="0 0 0" xyz="-0.015 0 -0.02"/>
    <axis xyz="0 1 0"/>
    <limit effort="0.1" velocity="30.0"/>
    <dynamics damping="0.005" friction="0.0"/>
  </joint>
  <link name="caster_wheel_link">
    <inertial>
      <mass value="0.02"/>
      <inertia ixx="5e-06" ixy="0" ixz="0" iyy="4e-06" iyz="0" izz="5e-06"/>
    </inertial>
    <visual>
      <origin rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.012" radius="0.02"/>
      </geometry>
      <material name="mcub_gray"/>
    </visual>
    <collision>
      <origin rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder length="0.012" radius="0.02"/>
      </geometry>
    </collision>
  </link>
  <!-- SLC1_link is the ROS LaserScan frame and is located on the scan plane. -->
  <joint name="base_to_SLC1" type="fixed">
    <parent link="base_link"/>
    <child link="SLC1_link"/>
    <origin rpy="0 0 3.141592653589793" xyz="0.0 0.0 0.14"/>
  </joint>
  <link name="SLC1_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 -0.0125"/>
      <mass value="0.11"/>
      <inertia ixx="2.5e-05" ixy="0" ixz="0" iyy="2.5e-05" iyz="0" izz="5e-05"/>
    </inertial>
    <!-- The cylinder center is the LiDAR scan line/plane. -->
    <visual>
      <geometry>
        <cylinder length="0.015" radius="0.025"/>
      </geometry>
      <material name="mcub_black"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.015" radius="0.025"/>
      </geometry>
    </collision>
  </link>
  <!-- Preserve the SLC1_base frame used by the current RViz configuration. -->
  <joint name="SLC1_base_joint" type="fixed">
    <parent link="SLC1_link"/>
    <child link="SLC1_base"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
  </joint>
  <link name="SLC1_base">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.02"/>
      <geometry>
        <box size="0.055 0.055 0.025"/>
      </geometry>
      <material name="mcub_black"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.02"/>
      <geometry>
        <box size="0.055 0.055 0.025"/>
      </geometry>
    </collision>
  </link>
  <!-- CubSim Editor import metadata. UnitySensorsROS is intentionally not used. -->
  <cubsim:sensor frequency="10.0" link="SLC1_link" max_range="12.0" min_range="0.05" name="slc1" samples="500" type="raycast_lidar"/>
</robot>
